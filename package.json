{
  "name": "@f3tchcodes/pepeblocks",
  "version": "1.1.0",
  "description": "JavaScript and TypeScript SDK for interacting with the Pepecoin (PEP) blockchain through the Pepeblocks API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f3tchcodes/pepeblocks.git"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "run": "tsc && node dist/index.js"
  },
  "keywords": [
    "pepecoin",
    "pep",
    "pepeblocks",
    "crypto",
    "blockchain",
    "typescript",
    "sdk"
  ],
  "author": "f3tch",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "imports": {
    "#interfaces/*": "./dist/interfaces/*.js",
    "#client/*": "./dist/client/*.js",
    "#utils/*": "./dist/utils/*.js",
    "#modules/*": "./dist/modules/*.js"
  }
}
